{
  "name": "propai-os",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "start": "turbo start",
    "lint": "turbo lint",
    "lint:fix": "turbo lint -- --fix",
    "typecheck": "turbo typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "db:generate": "pnpm --filter @propai/db db:generate",
    "db:migrate": "pnpm --filter @propai/db db:migrate",
    "db:studio": "pnpm --filter @propai/db db:studio",
    "db:rls-test": "pnpm --filter @propai/db db:rls-test",
    "test": "turbo test",
    "test:api": "pnpm --filter @propai/api test"
  },
  "devDependencies": {
    "eslint": "^9",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "turbo": "^2.5.4",
    "typescript": "^5"
  },
  "packageManager": "pnpm@11.5.0",
  "engines": {
    "node": ">=20"
  }
}
