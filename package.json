{
  "name": "propai-os",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/predev-check.mjs",
    "predev:check": "node scripts/predev-check.mjs",
    "dev": "turbo dev --filter=@propai/api --filter=@propai/web",
    "dev:all": "turbo dev",
    "dev:smoke": "node scripts/dev-stack-smoke.mjs",
    "web-build-smoke": "node scripts/web-build-smoke.mjs",
    "setup:local": "node scripts/setup-local.mjs",
    "build": "turbo build",
    "build:web": "turbo build --filter=@propai/web",
    "start": "turbo start",
    "lint": "turbo lint",
    "lint:fix": "turbo lint -- --fix",
    "typecheck": "turbo typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "db:generate": "pnpm --filter @propai/db db:generate",
    "db:migrate": "pnpm --filter @propai/db db:migrate",
    "db:studio": "pnpm --filter @propai/db db:studio",
    "db:rls-test": "pnpm --filter @propai/db db:rls-test",
    "db:seed-dev": "pnpm --filter @propai/db db:seed-dev",
    "db:seed": "pnpm --filter @propai/api seed:demo",
    "test": "turbo test",
    "test:api": "pnpm --filter @propai/api test",
    "test:shared": "pnpm --filter @propai/shared test",
    "auth:poc": "pnpm --filter @propai/api auth:poc"
  },
  "devDependencies": {
    "eslint": "^9",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "turbo": "^2.5.4",
    "typescript": "^5"
  },
  "packageManager": "pnpm@11.5.0",
  "engines": {
    "node": ">=20"
  }
}
