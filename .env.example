# PropAI OS — environment variables (copy to .env and fill in)
# Never commit .env or real secrets. All UI copy is en-US.
#
# Quick start (local):
#   cp .env.example .env
#   docker compose up -d
#   pnpm db:migrate
#   pnpm dev

# =============================================================================
# Required for local dev (Docker Compose + pnpm dev)
# =============================================================================
# | Variable            | Purpose                                      |
# |---------------------|----------------------------------------------|
# | NODE_ENV            | development                                  |
# | DATABASE_URL        | Migrations, Drizzle Studio, admin scripts    |
# | DATABASE_APP_URL    | API runtime — RLS-enforced app role          |
# | REDIS_URL           | BullMQ / cache (local Redis in Compose)      |
# | BETTER_AUTH_SECRET  | Session signing (min 32 characters)            |
# | BETTER_AUTH_URL     | Better Auth base URL (API origin)            |
# | API_URL             | Web app → API (server / middleware)          |
# | NEXT_PUBLIC_API_URL | Web app → API (browser fetch target)         |
# | NEXT_PUBLIC_APP_URL | Dashboard origin (CORS, auth callbacks)      |
# | PORT                | API listen port (default 3333)               |
# | HOST                | API bind address (default 0.0.0.0)           |

# =============================================================================
# Optional / cloud (leave empty for local-only work)
# =============================================================================
# | Variable                         | When needed                    |
# |----------------------------------|--------------------------------|
# | NEXT_PUBLIC_MARKETPLACE_URL      | Marketplace app (port 3001)    |
# | S3_*                             | Property photo uploads         |
# | RESEND_*                         | Transactional email            |
# | STRIPE_*                         | Billing (test keys in dev)     |
# | OPENAI_API_KEY / ANTHROPIC_*     | AI workers                     |
# | SENTRY_DSN / NEXT_PUBLIC_*       | Error tracking                 |
# | NEXT_PUBLIC_MAPBOX_TOKEN         | Maps                           |
# | ENABLE_AI_VISION / ENABLE_*      | Feature flags                  |

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_MARKETPLACE_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3333
API_URL=http://localhost:3333

# -----------------------------------------------------------------------------
# API server (Fastify — apps/api)
# -----------------------------------------------------------------------------
PORT=3333
HOST=0.0.0.0

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
#
# Two URLs — do not confuse them:
#
#   DATABASE_URL      — superuser / owner role (`propai` locally).
#                       Use for: pnpm db:migrate, db:studio, seeds, admin.
#
#   DATABASE_APP_URL  — non-superuser app role (`propai_app` locally).
#                       Use for: API runtime via getAppDb() — RLS enforced.
#                       Created by migration 0002_propai_app_role.sql.
#
# Local (after `docker compose up -d`):
#   DATABASE_URL=postgresql://propai:propai@localhost:5432/propai
#   DATABASE_APP_URL=postgresql://propai_app:propai_app@localhost:5432/propai
#
# Docker Compose profile `api` (API inside Docker network):
#   DATABASE_URL=postgresql://propai:propai@postgres:5432/propai
#   DATABASE_APP_URL=postgresql://propai_app:propai_app@postgres:5432/propai
#
# Production / preview (Neon):
#   DATABASE_URL=postgresql://user:password@host/db?sslmode=require
#   DATABASE_APP_URL=postgresql://app_role:password@host/db?sslmode=require
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://propai:propai@localhost:5432/propai
DATABASE_APP_URL=postgresql://propai_app:propai_app@localhost:5432/propai

# -----------------------------------------------------------------------------
# Redis
# Local: REDIS_URL=redis://localhost:6379
# Docker profile `api`: REDIS_URL=redis://redis:6379
# Production (Upstash): rediss://default:token@host:6379
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Auth (Better Auth — API on port 3333)
# BETTER_AUTH_SECRET: generate a random string — minimum 32 characters.
#   Example: openssl rand -base64 32
# -----------------------------------------------------------------------------
BETTER_AUTH_SECRET=generate-a-32-char-secret-minimum-length
BETTER_AUTH_URL=http://localhost:3333

# -----------------------------------------------------------------------------
# Object storage (Cloudflare R2 or MinIO — property photos, private bucket)
# See docs/infra/object-storage.md for R2 setup, CORS, and local MinIO profile.
#
# Local MinIO (docker compose --profile storage up -d):
#   S3_ENDPOINT=http://localhost:9000
#   S3_REGION=us-east-1
#   S3_ACCESS_KEY_ID=minioadmin
#   S3_SECRET_ACCESS_KEY=minioadmin
#
# Cloudflare R2:
#   S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
#   S3_REGION=auto
# -----------------------------------------------------------------------------
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=propai-uploads
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PRESIGN_EXPIRES_SECONDS=900

# -----------------------------------------------------------------------------
# Email (Resend)
# -----------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=notifications@yourdomain.com

# -----------------------------------------------------------------------------
# Billing (Stripe — test mode keys)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_

# -----------------------------------------------------------------------------
# AI (OpenAI or Anthropic — workers only; never block HTTP on LLM)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Observability (Sentry)
# -----------------------------------------------------------------------------
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# -----------------------------------------------------------------------------
# Maps (optional — geo / listing maps)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_MAPBOX_TOKEN=
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# -----------------------------------------------------------------------------
# Feature flags
# -----------------------------------------------------------------------------
ENABLE_AI_VISION=false
ENABLE_SEMANTIC_SEARCH=false
