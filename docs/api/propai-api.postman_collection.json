{
  "info": {
    "_postman_id": "propai-api-day12",
    "name": "PropAI OS API — Day 12–13",
    "description": "Day 12 ops: /health and /ready. Day 13 audit logs. Day 11 auth POC (M1–M6) and Day 10 reference requests included.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3333"
    },
    {
      "key": "ownerAEmail",
      "value": "owner-a-manual@test.propai-os.local"
    },
    {
      "key": "ownerBEmail",
      "value": "owner-b-manual@test.propai-os.local"
    },
    {
      "key": "agentEmail",
      "value": "agent-manual@test.propai-os.local"
    },
    {
      "key": "testPassword",
      "value": "password123"
    },
    {
      "key": "invitationId",
      "value": ""
    },
    {
      "key": "organizationIdA",
      "value": ""
    },
    {
      "key": "testEmail",
      "value": "owner@acme-brokerage.test"
    }
  ],
  "item": [
    {
      "name": "Day 12 — Ops",
      "description": "No auth. Run with API up (`pnpm --filter @propai/api dev`) and Postgres (`pnpm docker:up && pnpm db:migrate`).",
      "item": [
        {
          "name": "Health (liveness)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('status ok', function () {",
                  "  pm.expect(pm.response.json().status).to.eql('ok');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          }
        },
        {
          "name": "Ready (readiness / DB)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 when DB up', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('status ok', function () {",
                  "  pm.expect(pm.response.json().status).to.eql('ok');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/ready"
          }
        }
      ]
    },
    {
      "name": "Day 13 — Audit logs",
      "description": "Run after Postgres is up. Enable Postman cookies for localhost:3333. Flow: M1 sign-up → M2 list audit logs (owner).",
      "item": [
        {
          "name": "M1 — Brokerage Sign-Up (owner)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('organizationIdA', body.organization.id);",
                  "pm.test('activeOrganizationId matches org', function () {",
                  "  pm.expect(body.session.activeOrganizationId).to.eql(body.organization.id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"audit-owner-{{$guid}}@test.propai-os.local\",\n  \"password\": \"{{testPassword}}\",\n  \"name\": \"Audit Owner\",\n  \"organizationName\": \"Audit Brokerage {{$guid}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/brokerage-sign-up"
          }
        },
        {
          "name": "M2 — List audit logs (owner)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const body = pm.response.json();",
                  "const orgId = pm.collectionVariables.get('organizationIdA');",
                  "pm.test('organization.created present', function () {",
                  "  const found = body.items.some(function (e) {",
                  "    return e.action === 'organization.created' && e.entityId === orgId;",
                  "  });",
                  "  pm.expect(found).to.be.true;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/audit-logs?limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "audit-logs"],
              "query": [
                {
                  "key": "limit",
                  "value": "20"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Day 11 — Manual POC",
      "description": "Run M1 → M6 in order. Use fresh emails or reset DB between full runs. Enable Postman cookies for localhost:3333.",
      "item": [
        {
          "name": "M1 — Owner A sign-up + item",
          "item": [
            {
              "name": "Brokerage Sign Up (Owner A)",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('M1: Status 201', function () {",
                      "  pm.response.to.have.status(201);",
                      "});",
                      "",
                      "const body = pm.response.json();",
                      "pm.test('M1: activeOrganizationId matches org', function () {",
                      "  pm.expect(body.session.activeOrganizationId).to.eql(body.organization.id);",
                      "});",
                      "pm.collectionVariables.set('organizationIdA', body.organization.id);"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"{{ownerAEmail}}\",\n  \"password\": \"{{testPassword}}\",\n  \"name\": \"Owner A\",\n  \"organizationName\": \"Brokerage Alpha Manual\"\n}"
                },
                "url": "{{baseUrl}}/api/auth/brokerage-sign-up"
              }
            },
            {
              "name": "Create Test Item (Owner A)",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('M1: Item created 201', function () {",
                      "  pm.response.to.have.status(201);",
                      "});",
                      "const body = pm.response.json();",
                      "pm.test('M1: tenantId matches org A', function () {",
                      "  pm.expect(body.item.tenantId).to.eql(pm.collectionVariables.get('organizationIdA'));",
                      "});",
                      "pm.test('M1: Item name alpha-only-item', function () {",
                      "  pm.expect(body.item.name).to.eql('alpha-only-item');",
                      "});"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"alpha-only-item\"\n}"
                },
                "url": "{{baseUrl}}/v1/test-items"
              }
            }
          ]
        },
        {
          "name": "M2 — Owner B isolated tenant",
          "item": [
            {
              "name": "Brokerage Sign Up (Owner B)",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('M2: Status 201', function () {",
                      "  pm.response.to.have.status(201);",
                      "});",
                      "const body = pm.response.json();",
                      "pm.collectionVariables.set('organizationIdB', body.organization.id);"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"{{ownerBEmail}}\",\n  \"password\": \"{{testPassword}}\",\n  \"name\": \"Owner B\",\n  \"organizationName\": \"Brokerage Beta Manual\"\n}"
                },
                "url": "{{baseUrl}}/api/auth/brokerage-sign-up"
              }
            },
            {
              "name": "Create Test Item (Owner B)",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"beta-only-item\"\n}"
                },
                "url": "{{baseUrl}}/v1/test-items"
              }
            },
            {
              "name": "List Test Items (Owner B)",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('M2: Status 200', function () {",
                      "  pm.response.to.have.status(200);",
                      "});",
                      "const body = pm.response.json();",
                      "pm.test('M2: Only beta item visible', function () {",
                      "  pm.expect(body.items).to.have.lengthOf(1);",
                      "  pm.expect(body.items[0].name).to.eql('beta-only-item');",
                      "});",
                      "pm.test('M2: No alpha item from tenant A', function () {",
                      "  const names = body.items.map((i) => i.name);",
                      "  pm.expect(names).to.not.include('alpha-only-item');",
                      "});"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "GET",
                "header": [],
                "url": "{{baseUrl}}/v1/test-items"
              }
            }
          ]
        },
        {
          "name": "M3 — Owner A invites agent",
          "item": [
            {
              "name": "Brokerage Invite Agent",
              "event": [
                {
                  "listen": "prerequest",
                  "script": {
                    "exec": [
                      "// Re-run M1 sign-up first if cookies were cleared, or sign in as Owner A."
                    ],
                    "type": "text/javascript"
                  }
                },
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('M3: Status 201', function () {",
                      "  pm.response.to.have.status(201);",
                      "});",
                      "const body = pm.response.json();",
                      "pm.test('M3: Invitation pending', function () {",
                      "  pm.expect(body.invitation.status).to.eql('pending');",
                      "  pm.expect(body.invitation.role).to.eql('agent');",
                      "});",
                      "pm.collectionVariables.set('invitationId', body.invitation.id);"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"{{agentEmail}}\",\n  \"role\": \"agent\"\n}"
                },
                "url": "{{baseUrl}}/api/auth/brokerage-invite",
                "description": "Requires Owner A session cookie. Run M1 sign-up first in the same Postman cookie jar."
              }
            }
          ]
        },
        {
          "name": "M4 — Agent accepts invitation",
          "item": [
            {
              "name": "Sign Up Agent",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('M4: Agent sign-up 200', function () {",
                      "  pm.response.to.have.status(200);",
                      "});"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"{{agentEmail}}\",\n  \"password\": \"{{testPassword}}\",\n  \"name\": \"Agent Manual\"\n}"
                },
                "url": "{{baseUrl}}/api/auth/sign-up/email"
              }
            },
            {
              "name": "Accept Invitation",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('M4: Accept 200', function () {",
                      "  pm.response.to.have.status(200);",
                      "});",
                      "const body = pm.response.json();",
                      "pm.test('M4: Member in org A', function () {",
                      "  pm.expect(body.member.organizationId).to.eql(pm.collectionVariables.get('organizationIdA'));",
                      "});"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"invitationId\": \"{{invitationId}}\"\n}"
                },
                "url": "{{baseUrl}}/api/auth/organization/accept-invitation"
              }
            },
            {
              "name": "Get Session (Agent)",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('M4: Session 200', function () {",
                      "  pm.response.to.have.status(200);",
                      "});",
                      "const body = pm.response.json();",
                      "pm.test('M4: activeOrganizationId is org A', function () {",
                      "  pm.expect(body.session.activeOrganizationId).to.eql(pm.collectionVariables.get('organizationIdA'));",
                      "});"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "GET",
                "header": [],
                "url": "{{baseUrl}}/api/auth/get-session"
              }
            }
          ]
        },
        {
          "name": "M5 — Agent lists test-items",
          "item": [
            {
              "name": "List Test Items (Agent)",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('M5: Status 200', function () {",
                      "  pm.response.to.have.status(200);",
                      "});",
                      "const body = pm.response.json();",
                      "const orgA = pm.collectionVariables.get('organizationIdA');",
                      "pm.test('M5: Includes alpha item', function () {",
                      "  const names = body.items.map((i) => i.name);",
                      "  pm.expect(names).to.include('alpha-only-item');",
                      "});",
                      "pm.test('M5: Excludes beta item', function () {",
                      "  const names = body.items.map((i) => i.name);",
                      "  pm.expect(names).to.not.include('beta-only-item');",
                      "});",
                      "pm.test('M5: All items tenant A', function () {",
                      "  body.items.forEach((item) => {",
                      "    pm.expect(item.tenantId).to.eql(orgA);",
                      "  });",
                      "});"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "GET",
                "header": [],
                "url": "{{baseUrl}}/v1/test-items"
              }
            }
          ]
        },
        {
          "name": "M6 — Unauthorized",
          "item": [
            {
              "name": "List Test Items (no cookie)",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('M6: Status 401', function () {",
                      "  pm.response.to.have.status(401);",
                      "});",
                      "pm.test('M6: Unauthorized error', function () {",
                      "  const body = pm.response.json();",
                      "  pm.expect(body.error).to.eql('Unauthorized');",
                      "});"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "auth": {
                  "type": "noauth"
                },
                "method": "GET",
                "header": [],
                "url": "{{baseUrl}}/v1/test-items"
              }
            },
            {
              "name": "Sign In (wrong password)",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('M6: Wrong password not 200', function () {",
                      "  pm.expect(pm.response.code).to.not.eql(200);",
                      "});"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "auth": {
                  "type": "noauth"
                },
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"{{ownerAEmail}}\",\n  \"password\": \"wrong-password\",\n  \"rememberMe\": true\n}"
                },
                "url": "{{baseUrl}}/api/auth/sign-in/email"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Day 10 — Reference",
      "item": [
