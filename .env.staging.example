# PropAI OS — STAGING environment (Railway service variables)
# ---------------------------------------------------------------------------
# This file documents EVERY variable the cloud API + worker need. It is a
# template only — copy each value into the Railway *project* Variables tab
# (shared by both services). NEVER commit real secrets to git.
#
# Cloud pieces:
#   - Database  -> Neon        (DATABASE_URL / DATABASE_APP_URL)
#   - Redis     -> Upstash     (REDIS_BULLMQ_URL / REDIS_URL)  [rediss:// = TLS]
#   - API+Worker-> Railway     (runs docker/api/Dockerfile; see railway.*.json)
#
# See docs/tasks/PHASE-8-DAY-77-MANUAL.md for the click-by-click runbook.
# ===========================================================================

# --- Runtime -------------------------------------------------------------
NODE_ENV=production
# Railway injects PORT automatically; the API also honors this if set.
PORT=3333
HOST=0.0.0.0

# --- Database (Neon) -----------------------------------------------------
# IMPORTANT: migration 0002 runs `GRANT CONNECT ON DATABASE propai ...`, which
# is hardcoded to a database literally named `propai`. On Neon, create a
# database named `propai` (do NOT use the default `neondb`) or that migration
# fails. Both URLs must point at that `propai` database.
#
#   DATABASE_URL      -> owner role. Used ONLY by migrations (preDeployCommand).
#   DATABASE_APP_URL  -> propai_app RLS role (created by migration 0002).
#                        Used by the API + worker at runtime (getAppDb()).
DATABASE_URL=postgresql://neondb_owner:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/propai?sslmode=require
DATABASE_APP_URL=postgresql://propai_app:APP_PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/propai?sslmode=require

# --- Redis / BullMQ (Upstash) --------------------------------------------
# rediss:// (two s) = TLS, auto-detected by lib/redis-bullmq.ts. Do NOT paste
# the Upstash REST url (https://...) here — BullMQ needs the native protocol.
REDIS_BULLMQ_URL=rediss://default:TOKEN@HOST.upstash.io:6379
# Rate limiting / cache. Can reuse the same Upstash database.
REDIS_URL=rediss://default:TOKEN@HOST.upstash.io:6379

# --- Auth (Better Auth) --------------------------------------------------
# Generate: openssl rand -base64 32   (min 32 chars)
BETTER_AUTH_SECRET=REPLACE_WITH_32_CHAR_SECRET
# The public origin of the deployed API service.
BETTER_AUTH_URL=https://propai-api-staging.up.railway.app

# --- App URLs (public origins) -------------------------------------------
API_URL=https://propai-api-staging.up.railway.app
NEXT_PUBLIC_API_URL=https://propai-api-staging.up.railway.app
NEXT_PUBLIC_APP_URL=https://propai-web-staging.up.railway.app
WEB_APP_URL=https://propai-web-staging.up.railway.app
NEXT_PUBLIC_MARKETPLACE_URL=https://propai-marketplace-staging.up.railway.app
# The brokerage tenant the public marketplace renders (a real organization id).
NEXT_PUBLIC_MARKETPLACE_TENANT_ID=

# --- Object storage (Cloudflare R2 recommended for staging) --------------
S3_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=propai-uploads
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=
S3_PRESIGN_EXPIRES_SECONDS=900

# --- Email (Resend) ------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=notifications@yourdomain.com

# --- Billing (Stripe — test keys for staging) ----------------------------
STRIPE_SECRET_KEY=sk_test_
STRIPE_PRO_PRICE_ID=
STRIPE_WEBHOOK_SECRET=whsec_
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_

# --- AI (workers only — never block HTTP on an LLM) ----------------------
GEMINI_API_KEY=
OPENAI_API_KEY=

# --- Observability (Sentry) ----------------------------------------------
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# --- Feature flags -------------------------------------------------------
ENABLE_AI_VISION=false
ENABLE_SEMANTIC_SEARCH=false
ENABLE_AI_SCORING=false
ENABLE_AI_PRICING=false
